# Copie para .env se for rodar o SentinelAuth isolado.
# Nunca commite o arquivo .env.

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=SentinelAuthDb;Username=postgres;Password=troque-por-uma-senha-forte
Jwt__Issuer=SentinelAuth
Jwt__SecretKey=troque-por-uma-chave-jwt-com-64-caracteres-ou-mais

Seed__Ingressinhos__Enabled=true
Seed__Ingressinhos__ClientSecret=troque-por-um-client-secret-forte

Bootstrap__SuperAdmin__Enabled=true
Bootstrap__SuperAdmin__Email=admin@seu-dominio.com.br
Bootstrap__SuperAdmin__Password=troque-por-uma-senha-forte
Bootstrap__SuperAdmin__Name=Sentinel SuperAdmin

VITE_SENTINEL_AUTH_API_URL=https://auth-api.seu-dominio.com.br
VITE_DEFAULT_CLIENT_ID=ingressinhos-api
VITE_DEFAULT_REDIRECT_URI=ingressinhos://auth/callback
VITE_DEFAULT_STATE=
