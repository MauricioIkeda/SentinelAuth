FROM node:22-alpine AS build

WORKDIR /app

ARG VITE_SENTINEL_AUTH_API_URL
ARG VITE_DEFAULT_CLIENT_ID
ARG VITE_DEFAULT_REDIRECT_URI
ARG VITE_DEFAULT_STATE

ENV VITE_SENTINEL_AUTH_API_URL=$VITE_SENTINEL_AUTH_API_URL
ENV VITE_DEFAULT_CLIENT_ID=$VITE_DEFAULT_CLIENT_ID
ENV VITE_DEFAULT_REDIRECT_URI=$VITE_DEFAULT_REDIRECT_URI
ENV VITE_DEFAULT_STATE=$VITE_DEFAULT_STATE

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
